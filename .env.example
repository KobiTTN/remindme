# Токен бота від @BotFather
BOT_TOKEN=your_bot_token_here

# @username бота БЕЗ символу @  (потрібен для Telegram Login Widget)
BOT_USERNAME=your_bot_username

# Секретний ключ для підпису JWT (будь-який довгий рядок)
SECRET_KEY=change-me-to-a-long-random-string

# Публічна URL вашого додатку (без слешу в кінці)
# Потрібна для встановлення Telegram webhook
WEBHOOK_URL=https://your-app.railway.app
